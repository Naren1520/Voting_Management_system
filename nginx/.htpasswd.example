# This file is a placeholder. The real .htpasswd must be generated on your server.
#
# Run this command on your VPS to create nginx/.htpasswd:
#
#   htpasswd -cb nginx/.htpasswd YOUR_MONITORING_USER YOUR_MONITORING_PASSWORD
#
# Example:
#   htpasswd -cb nginx/.htpasswd admin 28627f35927d87025f5efcf55c11e27a
#
# If htpasswd is not installed:
#   sudo apt install apache2-utils   # Ubuntu/Debian
#   sudo yum install httpd-tools     # CentOS/RHEL
#
# The .htpasswd file is gitignored — never commit it.
# docker-compose.yml mounts it as: ./nginx/.htpasswd:/etc/nginx/.htpasswd:ro
