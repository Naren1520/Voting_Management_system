# Face Service environment variables
# Copy to .env and fill in values

# Shared secret between C++ backend and this service
FACE_API_SECRET=change-me-in-production

# Verification threshold (Change 2: configurable, no hardcoded values)
# Range: 0.0 - 1.0. Higher = stricter. Recommended: 0.80 - 0.85
FACE_THRESHOLD=0.82

# InsightFace model: buffalo_sc (CPU, fast) or buffalo_l (more accurate, needs GPU)
INSIGHTFACE_MODEL=buffalo_sc

# Minimum frames required from browser liveness sequence (Change 5)
LIVENESS_MIN_FRAMES=20

# CORS: comma-separated list of origins allowed to call this service
# Should be ONLY your C++ backend URL
FACE_ALLOWED_ORIGINS=https://votestack-cjom.onrender.com

# Server port
PORT=8000
