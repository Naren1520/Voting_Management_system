
#  Required: Supabase 
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

#  Optional: Redis (defaults to localhost if unset)
# When running with Docker Compose this is set automatically.
# REDIS_URL=redis://redis:6379

# Optional: CORS allowed origins (comma-separated)
# Defaults to Netlify frontend + localhost if unset. Set to * for open APIs.
# ALLOWED_ORIGINS=https://votestack.netlify.app,http://localhost:3000

#  Optional: Server tuning 
# PORT=8080
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW_SEC=60

#  Grafana credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_use_a_strong_password

#  Cloudflare
# Used by Certbot DNS plugin for wildcard certs.
# CLOUDFLARE_EMAIL=your-email@example.com
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
