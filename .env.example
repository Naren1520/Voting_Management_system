
#  Required: Supabase 
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

#  Required: Biometric embedding encryption (AES-256-GCM)
# Generate a key with: openssl rand -hex 32
# This key encrypts all biometric face embeddings at rest.
# NEVER commit this value. Rotate it by re-enrolling all voters.
# The server will REFUSE to start if this variable is missing or malformed.
EMBEDDING_ENCRYPTION_KEY=replace-with-output-of-openssl-rand-hex-32

#  Optional: Redis (defaults to localhost if unset)
# When running with Docker Compose this is set automatically.
# REDIS_URL=redis://redis:6379

#  Optional: Face verification service
# URL of the deployed Python face service (face-service/)
# FACE_SERVICE_URL=https://your-face-service.modal.run
# FACE_API_SECRET=change-me-in-production
# FACE_THRESHOLD=0.82

# Optional: CORS allowed origins (comma-separated)
# When unset the server reflects the request Origin header back, which is
# required for credentialed cross-origin requests (cookies + credentials:'include').
# In production, set this to your exact frontend origin(s):
# ALLOWED_ORIGINS=https://votestack.netlify.app,https://www.yourdomain.com
#
# Optional: disable the Secure flag on the session cookie for local HTTP dev.
# Set to 0 when running the server on plain http://localhost.
# MUST be left unset (or "1") in any HTTPS environment.
# SESSION_COOKIE_SECURE=0

#  Optional: Server tuning 
# PORT=8080
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW_SEC=60

#  Grafana credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_use_a_strong_password

#  Cloudflare
# Used by Certbot DNS plugin for wildcard certs.
# CLOUDFLARE_EMAIL=your-email@example.com
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
